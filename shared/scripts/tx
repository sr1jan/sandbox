#!/bin/bash
# tx — launch a tmuxinator project as the agent user, regardless of who
# you are. Forgetting `sudo -u agent -i` would normally start tmux as
# ubuntu — and any `claude` started in that session would bypass the
# cred-guard hooks (which live in /home/agent/.claude/, not ubuntu's
# home). tx removes the footgun: always agent, every time.
#
# Usage:
#   tx                # tmuxinator start dev (default)
#   tx fun            # tmuxinator start fun
#   tx <project>      # any tmuxinator project under ~agent/.config/tmuxinator/

set -euo pipefail

NAME="${1:-dev}"

# Re-enter as agent if invoked by another user. Recurses into tx (not
# straight to tmuxinator) so the inside-tmux check below still fires.
#
# `sudo -u agent -i` runs a clean login shell that wipes TMUX. That's
# fine when called from a plain shell, but it breaks `tx fun` invoked
# from inside the dev session's admin pane (which is `sudo -i` root in
# agent's own tmux): the inner TMUX check at the next block can't tell
# we're already in a tmux pane, so it nests instead of switch-client.
# Re-inject TMUX into the agent shell to fix that case.
if [ "$(id -un)" != "agent" ]; then
  if [ -n "${TMUX:-}" ]; then
    exec sudo -u agent -i bash -c "TMUX=$(printf %q "$TMUX") exec tx $(printf %q "$NAME")"
  else
    exec sudo -u agent -i tx "$NAME"
  fi
fi

# Inside an existing agent tmux: don't let tmuxinator attach a second
# client (that nests the new session inside the current pane and leaves
# the old one attached too). Build detached, then switch the current
# client over.
if [ -n "${TMUX:-}" ]; then
  tmux has-session -t "$NAME" 2>/dev/null \
    || tmuxinator start "$NAME" --no-attach
  exec tmux switch-client -t "$NAME"
fi

exec tmuxinator start "$NAME"
