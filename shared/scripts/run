#!/bin/bash
# Runs a command with credentials loaded. Called via: sudo run <command>
#
# 1. Loads global CLI credentials (/etc/devbox/secrets)
# 2. Loads project-local credentials (.env in cwd)
# 3. Drops privileges to 'agent' user
# 4. Execs the command
#
# The agent user cannot read the secrets files directly.
# This script runs as root (via sudo) and drops privileges after loading.

set -euo pipefail

# Global credentials from locked location (gh, aws, gcloud, etc.)
GLOBAL_SECRETS="/etc/devbox/locked/secrets"
if [ -f "$GLOBAL_SECRETS" ]; then
  set -a
  source "$GLOBAL_SECRETS"
  set +a
fi

# Project-local credentials from locked location
# Entrypoint copies .env files from /workspace/<project>/ to /etc/devbox/locked/projects/<project>/
CWD="$(pwd)"
REL="${CWD#/workspace/}"
LOCKED_DIR="/etc/devbox/locked/projects/$REL"
for f in .env .env.local .env.secrets .env.development; do
  if [ -f "$LOCKED_DIR/$f" ]; then
    set -a
    source "$LOCKED_DIR/$f"
    set +a
  fi
done

# Fallback: also try cwd (for VM mode where file permissions work natively)
for f in .env .env.local .env.secrets .env.development; do
  if [ -f "$f" ]; then
    set -a
    source "$f"
    set +a
  fi
done

if [ $# -eq 0 ]; then
  echo "Usage: sudo run <command> [args...]"
  exit 1
fi

# Drop to agent user and exec
exec gosu agent "$@"
