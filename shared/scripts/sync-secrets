#!/bin/bash
# sync-secrets — atomic upsert of KEY=value lines into
# /etc/devbox/locked/secrets. Root-only; reads stdin.
#
# For each KEY=value (or `export KEY=value`) line on stdin:
#   - removes any existing line in the secrets file with the same KEY
#   - appends the new line as `export KEY=value`
# Atomic write (tmpfile + mv), perms 600 root:root.
# Comments (#...) and blank lines are skipped silently.
# Keys are validated to match [A-Z_][A-Z0-9_]*.
#
# Logs each upserted KEY to stderr. Values are NEVER logged.
#
# Usage:
#   echo 'export AWS_ACCESS_KEY_ID=AKIA...' | sudo sync-secrets
#   sudo sync-secrets < some-env-file

set -euo pipefail

if [ "$(id -u)" -ne 0 ]; then
  echo "sync-secrets: must run as root (try: sudo sync-secrets)" >&2
  exit 1
fi

SECRETS=/etc/devbox/locked/secrets
SECRETS_DIR="$(dirname "$SECRETS")"

mkdir -p "$SECRETS_DIR"
chown root:root "$SECRETS_DIR"
chmod 700 "$SECRETS_DIR"
[ -f "$SECRETS" ] || install -m 600 -o root -g root /dev/null "$SECRETS"

TMP="$(mktemp -p "$SECRETS_DIR" .secrets.XXXXXX)"
trap 'rm -f "$TMP"' EXIT
chmod 600 "$TMP"
cp "$SECRETS" "$TMP"

UPSERTED=()
KEY_RE='^[A-Z_][A-Z0-9_]*$'

while IFS= read -r line || [ -n "$line" ]; do
  case "$line" in
    ''|\#*) continue ;;
  esac
  bare="${line#export }"
  bare="${bare# }"
  case "$bare" in
    *=*) ;;
    *) echo "sync-secrets: skipping malformed line: ${line%%=*}..." >&2; continue ;;
  esac
  key="${bare%%=*}"
  val="${bare#*=}"
  if ! [[ "$key" =~ $KEY_RE ]]; then
    echo "sync-secrets: skipping invalid key: $key" >&2
    continue
  fi
  # Skip empty values — bootstrap passes optional secrets through unconditionally,
  # so a blank value means "operator didn't set it; don't pollute the file".
  if [ -z "$val" ]; then
    continue
  fi
  # Remove any existing line for this key (with or without `export`)
  sed -i.bak -E "/^[[:space:]]*(export[[:space:]]+)?${key}=/d" "$TMP"
  rm -f "${TMP}.bak"
  # Single-quote the value so shell metacharacters ($, `, etc.) are preserved
  # at source time. Embedded single quotes are escaped via the standard
  # '\'' pattern.
  escaped="$(printf '%s' "$val" | sed "s/'/'\\\\''/g")"
  printf "export %s='%s'\n" "$key" "$escaped" >> "$TMP"
  UPSERTED+=("$key")
done

mv "$TMP" "$SECRETS"
chown root:root "$SECRETS"
chmod 600 "$SECRETS"

if [ "${#UPSERTED[@]}" -gt 0 ]; then
  echo "sync-secrets: upserted ${#UPSERTED[@]} key(s): ${UPSERTED[*]}" >&2
else
  echo "sync-secrets: nothing to do (no valid KEY=value lines on stdin)" >&2
fi
