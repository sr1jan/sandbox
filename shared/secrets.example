# Sandbox global secrets — sourced by `sudo run <command>` from
# /etc/devbox/locked/secrets (root:600).
#
# Use `sudo sync-secrets` to populate (idempotent upsert from stdin),
# OR `sudo vi /etc/devbox/locked/secrets` to edit by hand.
#
# Per-project .env files go in /etc/devbox/locked/projects/<project>/,
# NOT in this file.

# ---- GitHub ----
# GitHub auth on the VM is via SSH/GPG keys, not tokens. The keys live in
# /home/agent/.ssh and /home/agent/.gnupg, populated by sync-ssh-keys.sh
# from ~/.sandbox-keys/ on your Mac. No GH_TOKEN needed in this file.
# (If you separately want `gh api` to work for skills/agents, run
# `gh auth login` manually as agent — not handled by bootstrap.)

# ---- AWS ----
# Sandbox IAM user keys. Created by terraform; populate via
# `./hosts/aws-ec2/sync-aws-keys.sh <workspace>` (no manual copy/paste).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# ---- Anthropic (optional) ----
# If set, Claude Code skips the device-flow login. Otherwise the agent
# is prompted on first `claude` invocation.
# ANTHROPIC_API_KEY=

# ---- Staging Postgres ----
# Used by the deepreel-db skill (`scripts/config.json` "staging" target).
# Setting either staging or replica host opens outbound 5432 in the SG.
# STAGING_DB_HOST=
# STAGING_DB_NAME=
# STAGING_DB_USER=
# STAGING_DB_PASSWORD=

# ---- Prod Postgres replica ----
# Used by the deepreel-db skill (`scripts/config.json` "replica" target).
# Setting either staging or replica host opens outbound 5432 in the SG.
# Role on prod is read-only enforced.
# DATABASE_REPLICA_HOST=
# DATABASE_REPLICA_NAME=
# DATABASE_REPLICA_USER=
# DATABASE_REPLICA_PASSWORD=

# ---- GCP (optional) ----
# Path to a service-account JSON. Auto-exported by `run` if a file matching
# /etc/devbox/locked/projects/<proj>/creds/{service-account,google-sa,*-sa}.json
# is found, so usually leave this commented out.
# GOOGLE_APPLICATION_CREDENTIALS=/etc/devbox/locked/gcp-sa.json
