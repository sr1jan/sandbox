# Global CLI credentials — used by 'sudo run <command>'
# Copy to 'secrets' and fill in values:
#   cp secrets.example secrets

# GitHub
GH_TOKEN=

# AWS (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# GCP (optional — only needed in Docker, VM uses instance service account)
# GOOGLE_APPLICATION_CREDENTIALS=/etc/devbox/gcp-sa.json
