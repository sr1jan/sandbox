# Real credentials — NEVER commit
hosts/docker-mac/secrets
*.pem
*.key
# SSH private keys (no extension — catches id_ed25519_personal etc.)
id_ed25519*
id_rsa*
id_ecdsa*
id_dsa*
# GPG armored exports + binary keyrings
*.asc
*.gpg
# Operator's local staging dir for sandbox-vm keys (Mac side)
.sandbox-keys/

# Docker build artifacts
hosts/docker-mac/.env

# Terraform state and provider cache (local state is per-workspace)
hosts/*/terraform/.terraform/
hosts/*/terraform/terraform.tfstate
hosts/*/terraform/terraform.tfstate.*
hosts/*/terraform/terraform.tfstate.d/
hosts/*/terraform/*.tfvars   # workspace tfvars live in workspaces/, not here

# macOS cruft
.DS_Store

# Tool caches
.cachebro/
