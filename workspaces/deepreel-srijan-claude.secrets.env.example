# Copy this file to workspaces/deepreel-srijan-claude.secrets.env
# (gitignored) and fill in the real values.
#
# Load into environment before `terraform apply`:
#   set -a
#   source workspaces/deepreel-srijan-claude.secrets.env
#   set +a

# ---- Tailscale OAuth (provider auth, not propagated to VM) ----
# Admin Console → Settings → OAuth clients; scopes: auth_keys (write), devices (read)
export TF_VAR_tailscale_oauth_client_id="<paste from Tailscale Admin Console>"
export TF_VAR_tailscale_oauth_client_secret="<paste from Tailscale Admin Console>"

# ---- Operator-supplied VM secrets ----
# These are passed via terraform → user-data → bootstrap → /etc/devbox/locked/secrets.
# Bootstrap skips empty values, so leave optional ones blank.

# GitHub PAT for cloning private deepreel/* repos. Required if
# deepreel_repo_urls in the .tfvars is non-empty. Scope: read on deepreel org.
export TF_VAR_gh_token_deepreel=""

# Optional: PAT for sr1jan/sandbox (only needed if the agent will write
# back to its own infra repo; sandbox is public, no token needed for read).
export TF_VAR_gh_token_sandbox=""

# Optional: Anthropic API key. If empty, Claude Code device-flow logs in
# on first invocation.
export TF_VAR_anthropic_api_key=""

# ---- Prod replica DB ----
# Used by the deepreel-db skill ("replica" target). Setting
# TF_VAR_database_replica_host also opens outbound 5432 in the SG —
# no separate tfvar to flip.
export TF_VAR_database_replica_host=""
export TF_VAR_database_replica_name=""
export TF_VAR_database_replica_user=""
export TF_VAR_database_replica_password=""
